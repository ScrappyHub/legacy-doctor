{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ld.device.health.receipt.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_type",
    "ok",
    "repo_root",
    "device_id",
    "disk_number",
    "health_summary",
    "signals",
    "preservation_recommendation"
  ],
  "properties": {
    "schema": { "type": "string", "const": "ld.device.health.receipt.v1" },
    "event_type": { "type": "string", "const": "ld.device.health.receipt.v1" },
    "ok": { "type": "boolean" },
    "repo_root": { "type": "string", "minLength": 1 },
    "device_id": { "type": "string", "minLength": 1 },
    "disk_number": { "type": "integer", "minimum": 0 },
    "health_summary": {
      "type": "string",
      "enum": [
        "UNKNOWN",
        "HEALTHY",
        "WARNING",
        "AT_RISK",
        "UNREADABLE"
      ]
    },
    "signals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "preservation_recommendation": {
      "type": "string",
      "enum": [
        "READ_ONLY_BACKUP_FIRST",
        "SAFE_FILE_COPY",
        "RAW_IMAGE_RECOMMENDED",
        "FORMAT_ONLY_AFTER_CAPTURE",
        "NO_MEDIA_PRESENT"
      ]
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}