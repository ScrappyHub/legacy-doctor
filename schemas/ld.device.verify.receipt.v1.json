{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ld.device.verify.receipt.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_type",
    "ok",
    "repo_root",
    "image_path",
    "manifest_path",
    "chunk_size_bytes",
    "image_sha256",
    "chunk_count",
    "verification_result"
  ],
  "properties": {
    "schema": { "type": "string", "const": "ld.device.verify.receipt.v1" },
    "event_type": { "type": "string", "const": "ld.device.verify.receipt.v1" },
    "ok": { "type": "boolean" },
    "repo_root": { "type": "string", "minLength": 1 },
    "device_id": { "type": "string" },
    "disk_number": { "type": ["integer", "null"], "minimum": 0 },
    "image_path": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string", "minLength": 1 },
    "chunk_size_bytes": { "type": "integer", "minimum": 1 },
    "image_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "chunk_count": { "type": "integer", "minimum": 0 },
    "verification_result": {
      "type": "string",
      "enum": [
        "VERIFY_OK",
        "VERIFY_FAIL_MANIFEST_SCHEMA",
        "VERIFY_FAIL_IMAGE_MISSING",
        "VERIFY_FAIL_MANIFEST_MISSING",
        "VERIFY_FAIL_CHUNK_COUNT",
        "VERIFY_FAIL_CHUNK_OFFSET",
        "VERIFY_FAIL_CHUNK_SIZE",
        "VERIFY_FAIL_CHUNK_HASH",
        "VERIFY_FAIL_IMAGE_HASH",
        "VERIFY_FAIL_EXTRA_BYTES"
      ]
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}