{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ld.fat32.imagefile.receipt.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event_type",
    "ok",
    "repo_root",
    "image_path",
    "image_sha256",
    "plan_sha256",
    "disk_size_bytes",
    "bytes_per_sector",
    "device_id",
    "disk_number",
    "partition_start_lba",
    "partition_size_lba",
    "sectors_per_cluster",
    "reserved_sectors",
    "fat_count",
    "fat_size_sectors",
    "root_cluster",
    "label",
    "sector_hashes"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "ld.fat32.imagefile.receipt.v1"
    },
    "event_type": {
      "type": "string",
      "const": "ld.fat32.imagefile.receipt.v1"
    },
    "ok": {
      "type": "boolean"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "image_path": {
      "type": "string",
      "minLength": 1
    },
    "image_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "plan_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "disk_size_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "bytes_per_sector": {
      "type": "integer",
      "minimum": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "disk_number": {
      "type": "integer",
      "minimum": 0
    },
    "partition_start_lba": {
      "type": "integer",
      "minimum": 1
    },
    "partition_size_lba": {
      "type": "integer",
      "minimum": 1
    },
    "sectors_per_cluster": {
      "type": "integer",
      "minimum": 1
    },
    "reserved_sectors": {
      "type": "integer",
      "minimum": 1
    },
    "fat_count": {
      "type": "integer",
      "minimum": 1
    },
    "fat_size_sectors": {
      "type": "integer",
      "minimum": 1
    },
    "root_cluster": {
      "type": "integer",
      "minimum": 2
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 11
    },
    "sector_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mbr",
        "boot",
        "fsinfo",
        "backup_boot",
        "fat0",
        "root0"
      ],
      "properties": {
        "mbr": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "boot": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "fsinfo": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "backup_boot": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "fat0": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "root0": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
